---
import { useTranslations, getNavLinks, getAlternateLocalePath } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import WorkMegaMenu from '../components/nav/WorkMegaMenu.astro';
import WhatWeDoMegaMenu from '../components/nav/WhatWeDoMegaMenu.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  ogImage?: ImageMetadata;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, locale, ogImage, jsonLd } = Astro.props;
const t = useTranslations(locale);
const nav = getNavLinks(locale);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const altLocale = locale === 'pt' ? 'en' : 'pt';
const altPath = getAlternateLocalePath(Astro.url.pathname, locale);

let ogImageUrl: string | undefined;
if (ogImage) {
  const optimized = await getImage({
    src: ogImage,
    width: 1200,
    height: 630,
    fit: 'cover',
    format: 'jpg',
  });
  ogImageUrl = new URL(optimized.src, Astro.site ?? Astro.url).href;
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImageUrl} />
      </>
    )}
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={altLocale} href={new URL(altPath, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-vinco-cream text-vinco-black font-body">

    <!-- NAV -->
    <header class="sticky top-0 z-50 bg-vinco-cream border-b border-vinco-brown-1/20">
      <nav class="max-w-[1440px] mx-auto px-8 h-16 flex items-center justify-between">

        <!-- Logo -->
        <a href={nav.home} class="block">
          <img 
            src="/images/vinco-logo.svg" 
            alt="Vinco Estúdio" 
            class="h-6 w-auto"
          />
        </a>

        <!-- Links (center) -->
 <!-- Links (center) -->
    <ul class="hidden md:flex items-center gap-8">
      <WorkMegaMenu
        locale={locale}
        workLabel={t.nav.work}
        caseStudiesLabel={t.nav['work-case-studies']}
        workCta={t.home.work_cta}
        workUrl={nav.work}
      />
      <WhatWeDoMegaMenu
        locale={locale}
        label={t.nav['what-we-do']}
        categoriesTitle={t.home.categories_title}
        categoriesAll={t.work.categories_all}
        categoriesUrl={nav.whatWeDo}
      />
      <li><a href={nav.about} class="nav-link">{t.nav.about}</a></li>
      <li><a href={nav.contact} class="nav-link">{t.nav.contact}</a></li>
    </ul>

    <script>
      import '../components/nav/mega-menu.ts';
    </script>

        <!-- Language toggle -->
        <a
          href={altPath}
          class="text-xs tracking-widest uppercase text-vinco-brown-1 hover:text-vinco-burgundy transition-colors duration-150"
        >
          {altLocale.toUpperCase()}
        </a>

      </nav>
    </header>

    <!-- CONTENT -->
    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="bg-vinco-black text-vinco-cream">
      <div class="max-w-[1440px] mx-auto px-8 py-16">

        <div class="flex flex-col md:flex-row justify-between gap-12">

          <!-- Logo + Tagline -->
          <div class="max-w-xs">
            <a href={nav.home} class="block mb-6">
              <img
                src="/images/vinco-logo.svg"
                alt="Vinco Estúdio"
                class="h-6 w-auto brightness-0 invert"
              />
            </a>
            <p class="font-heading text-lg tracking-tight text-vinco-cream whitespace-pre-line">
              {t.footer.tagline}
            </p>
          </div>

          <!-- Nav links -->
          <nav class="flex flex-col gap-3">
            <a href={nav.work} class="footer-link">{t.nav.work}</a>
            <a href={nav.whatWeDo} class="footer-link">{t.nav['what-we-do']}</a>
            <a href={nav.about} class="footer-link">{t.nav.about}</a>
            <a href={nav.contact} class="footer-link">{t.nav.contact}</a>
          </nav>

          <!-- Contact + Social -->
          <div class="flex flex-col gap-4">
            <a href={`mailto:${t.footer.email}`} class="footer-link">
              {t.footer.email}
            </a>
            <div class="flex gap-4">
              <a href={t.footer.social.instagram} target="_blank" rel="noopener noreferrer" class="footer-link">Instagram</a>
              <a href={t.footer.social.linkedin} target="_blank" rel="noopener noreferrer" class="footer-link">LinkedIn</a>
            </div>
          </div>

        </div>

        <!-- Copyright -->
        <div class="mt-16 pt-8 border-t border-vinco-cream/10">
          <p class="text-xs text-vinco-brown-1">{t.footer.rights}</p>
        </div>

      </div>
    </footer>

  </body>
</html>