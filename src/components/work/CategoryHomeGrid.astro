---
import MultilineText from '../MultilineText.astro';
import CategoryHomeCard from './CategoryHomeCard.astro';
import { categories } from '../../data/work';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  ctaLabel: string;
  ctaUrl: string;
}

const { locale, title, ctaLabel, ctaUrl } = Astro.props;
---

<div class="flex items-baseline justify-between mb-12">
  <h2 class="font-display text-vinco-cream"><MultilineText text={title} /></h2>
  <a
    href={ctaUrl}
    class="text-sm text-vinco-cream/60 hover:text-vinco-cream transition-colors duration-150"
  >
    {ctaLabel} →
  </a>
</div>
<div class="grid grid-cols-2 md:grid-cols-3 border-t border-l border-vinco-cream/10 overflow-visible">
  {categories.map((cat) => (
    <CategoryHomeCard category={cat} locale={locale} />
  ))}
</div>
