---
import OptimizedImage from '../OptimizedImage.astro';
import CategoryGrid from './CategoryGrid.astro';
import { categories, getCategoryItems } from '../../data/work';
import type { Locale } from '../../i18n/utils';
import { useTranslations } from '../../i18n/utils';

interface Props {
  locale: Locale;
  activeSlug: string | null;
  baseUrl: string;
}

const { locale, activeSlug, baseUrl } = Astro.props;
const t = useTranslations(locale);
---

<div class="category-filter" data-base-url={baseUrl}>
  <CategoryGrid
    locale={locale}
    variant="interactive"
    activeSlug={activeSlug}
  />

  <div class="mt-12" data-category-results>
    <p
      class:list={['text-vinco-cream/60 text-sm', activeSlug && 'hidden']}
      data-category-empty
    >
      {t.work.categories_select}
    </p>

    {categories.map((cat) => {
      const items = getCategoryItems(cat.slug);
      const isActive = activeSlug === cat.slug;
      return (
        <div
          data-category-panel={cat.slug}
          class:list={['category-panel', !isActive && 'hidden']}
        >
          {items.length > 0 ? (
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              {items.map((item) => (
                <div class="aspect-square bg-vinco-cream/5 overflow-hidden">
                  <OptimizedImage
                    src={item.src}
                    alt={item.alt}
                    class="w-full h-full object-cover"
                    sizes="(max-width: 768px) 50vw, 25vw"
                  />
                </div>
              ))}
            </div>
          ) : (
            <p class="text-vinco-cream/60 text-sm">{t.work.categories_select}</p>
          )}
        </div>
      );
    })}
  </div>
</div>

<script>
  function initCategoryFilter(root: HTMLElement) {
    const baseUrl = root.dataset.baseUrl ?? '';
    const emptyMsg = root.querySelector('[data-category-empty]');
    const cells = root.querySelectorAll('[data-category-slug]');

    function getPanels(): NodeListOf<Element> {
      return root.querySelectorAll('[data-category-panel]');
    }

    function showPanel(slug: string) {
      getPanels().forEach((panel) => {
        panel.classList.toggle('hidden', panel.getAttribute('data-category-panel') !== slug);
      });

      if (emptyMsg) emptyMsg.classList.add('hidden');

      cells.forEach((cell) => {
        const isActive = cell.getAttribute('data-category-slug') === slug;
        cell.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        cell.classList.toggle('bg-vinco-cream/10', isActive);
        cell.classList.toggle('ring-1', isActive);
        cell.classList.toggle('ring-inset', isActive);
        cell.classList.toggle('ring-vinco-burgundy/50', isActive);
      });

      history.pushState({ categoria: slug }, '', `${baseUrl}?categoria=${slug}`);
    }

    function clearSelection() {
      getPanels().forEach((p) => p.classList.add('hidden'));
      if (emptyMsg) emptyMsg.classList.remove('hidden');
      cells.forEach((cell) => {
        cell.setAttribute('aria-pressed', 'false');
        cell.classList.remove('bg-vinco-cream/10', 'ring-1', 'ring-inset', 'ring-vinco-burgundy/50');
      });
    }

    cells.forEach((cell) => {
      cell.addEventListener('click', () => {
        const slug = cell.getAttribute('data-category-slug');
        if (slug) showPanel(slug);
      });
    });

    window.addEventListener('popstate', () => {
      const slug = new URLSearchParams(window.location.search).get('categoria');
      if (slug) showPanel(slug);
      else clearSelection();
    });
  }

  document.querySelectorAll('.category-filter').forEach((el) => {
    initCategoryFilter(el as HTMLElement);
  });
</script>
