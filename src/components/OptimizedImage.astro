---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  sizes?: string;
  widths?: number[];
  priority?: boolean;
}

const {
  src,
  alt,
  class: className,
  loading = 'lazy',
  sizes = '(max-width: 768px) 100vw, 50vw',
  widths = [400, 800, 1200, 1600],
  priority = false,
} = Astro.props;
---

<Image
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  format="webp"
  quality={80}
  loading={priority ? 'eager' : loading}
  fetchpriority={priority ? 'high' : undefined}
  class={className}
/>
