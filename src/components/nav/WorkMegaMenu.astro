---
import ProjectCard from '../work/ProjectCard.astro';
import { getFeaturedProjects } from '../../data/work';
import type { Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
  workLabel: string;
  caseStudiesLabel: string;
  workCta: string;
  workUrl: string;
}

const { locale, workLabel, caseStudiesLabel, workCta, workUrl } = Astro.props;
const featuredProjects = getFeaturedProjects();
---

<li class="group relative" data-mega-menu>
  <a
    href={workUrl}
    class="nav-link"
    aria-haspopup="true"
    aria-expanded="false"
    data-mega-trigger
  >
    {workLabel}
  </a>

  <div
    class="absolute left-1/2 -translate-x-1/2 top-full pt-2 opacity-0 invisible pointer-events-none
           group-hover:opacity-100 group-hover:visible group-hover:pointer-events-auto
           group-focus-within:opacity-100 group-focus-within:visible group-focus-within:pointer-events-auto
           transition-all duration-150 z-40"
    data-mega-panel
  >
    <div
      class="w-[min(90vw,560px)] bg-vinco-cream border border-vinco-brown-1/20 shadow-[var(--shadow-card)] p-8"
    >
      <p class="text-xs tracking-widest uppercase text-vinco-brown-1 mb-4">
        {caseStudiesLabel}
      </p>
      <div class="grid grid-cols-3 gap-4 mb-6">
        {featuredProjects.map((project) => (
          <ProjectCard project={project} locale={locale} variant="compact" />
        ))}
      </div>
      <a href={workUrl} class="nav-sublink text-sm">
        {workCta} →
      </a>
    </div>
  </div>
</li>
