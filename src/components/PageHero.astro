---
import MultilineText from './MultilineText.astro';
import { splitCopyParagraphs } from '../i18n/utils';

interface Props {
  title: string;
  intro: string | string[];
}

const { title, intro } = Astro.props;

const introParagraphs = Array.isArray(intro) ? intro : splitCopyParagraphs(intro);
---

<section class="bg-vinco-cream border-t border-vinco-brown-1/20 relative px-8 py-24 min-h-[22rem] md:min-h-[24rem] overflow-hidden">
  <div
    class="absolute top-0 right-0 w-1/2 h-full hidden md:block pointer-events-none opacity-10"
    style="background-image: url('/images/patterns/pattern-cream.svg'); background-size: 300px; background-repeat: repeat;"
    aria-hidden="true"
  ></div>
  <div class="max-w-[1440px] mx-auto relative z-10 grid grid-cols-1 md:grid-cols-2">
    <div class="max-w-2xl md:max-w-none md:pr-12">
      <h1 class="font-display text-vinco-black mb-4">
        <MultilineText text={title} />
      </h1>
      <div class="space-y-6">
        {
          introParagraphs.map((paragraph) => (
            <p class="text-vinco-black/70 leading-relaxed">
              <MultilineText text={paragraph} />
            </p>
          ))
        }
      </div>
    </div>
  </div>
</section>
