---
import Base from '../../layouts/Base.astro';
import MultilineText from '../../components/MultilineText.astro';
import CaseStudySection from '../../components/work/CaseStudySection.astro';
import { useTranslations } from '../../i18n/utils';
import { getCaseStudies, getCaseStudyCopyKey, getProjectGallery, formatProjectPeriod, getDefaultOgImage } from '../../data/work';

const locale = 'en';
const t = useTranslations(locale);
const caseStudies = getCaseStudies();
const caseCopyByKey = t.work.cases;
---

<Base
  title={`${t.work.title} | Vinco Studio`}
  description={t.work.intro}
  locale={locale}
  ogImage={getDefaultOgImage()}
>
  <section class="bg-vinco-cream border-t border-vinco-brown-1/20 px-8 py-24">
    <div class="max-w-[1440px] mx-auto">
      <div class="mb-16 max-w-2xl">
        <h1 class="font-display text-vinco-black mb-4">
          <MultilineText text={t.home.work_title} />
        </h1>
        <p class="text-vinco-black/70 leading-relaxed">
          <MultilineText text={t.work.intro} />
        </p>
      </div>
      <div>
        {
          caseStudies.map((project) => {
            const copyKey = getCaseStudyCopyKey(project.slug);
            const caseCopy = copyKey
              ? caseCopyByKey[copyKey as keyof typeof caseCopyByKey]
              : undefined;

            return (
              <CaseStudySection
                id={project.slug}
                title={caseCopy?.title ?? project.client}
                tag={project.category[locale]}
                period={formatProjectPeriod(project.period, locale)}
                description={caseCopy?.description ?? ''}
                gallery={getProjectGallery(project)}
                imageAlt={caseCopy?.title ?? project.client}
              />
            );
          })
        }
      </div>
    </div>
  </section>
</Base>
