---
import Base from '../../layouts/Base.astro';
import MultilineText from '../../components/MultilineText.astro';
import CategoryFilter from '../../components/work/CategoryFilter.astro';
import { useTranslations, getNavLinks } from '../../i18n/utils';
import { getCategoryBySlug } from '../../data/work';

const locale = 'en';
const t = useTranslations(locale);
const nav = getNavLinks(locale);

const rawSlug = Astro.url.searchParams.get('categoria');
const activeSlug = rawSlug && getCategoryBySlug(rawSlug) ? rawSlug : null;
---

<Base
  title={`${t.home.categories_title} | Vinco Studio`}
  description={t.work.categories_intro}
  locale={locale}
>
  <section class="bg-vinco-black px-8 py-24">
    <div class="max-w-[1440px] mx-auto">
      <div class="mb-12 max-w-2xl">
        <h1 class="font-display text-vinco-cream mb-4">
          <MultilineText text={t.home.categories_title} />
        </h1>
        <p class="text-vinco-cream/70 leading-relaxed">{t.work.categories_intro}</p>
      </div>

      <CategoryFilter
        locale={locale}
        activeSlug={activeSlug}
        baseUrl={nav.whatWeDo}
      />
    </div>
  </section>
</Base>
