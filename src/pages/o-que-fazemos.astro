---
import Base from '../layouts/Base.astro';
import MultilineText from '../components/MultilineText.astro';
import CategoryNav from '../components/work/CategoryNav.astro';
import CategorySection from '../components/work/CategorySection.astro';
import { useTranslations } from '../i18n/utils';
import { categories, getCategoryItems } from '../data/work';

const locale = 'pt';
const t = useTranslations(locale);
---

<Base
  title={`${t.home.categories_title} | Vinco Estúdio`}
  description={t.work.categories_intro}
  locale={locale}
>
  <section class="bg-vinco-black px-8 py-24">
    <div class="max-w-[1440px] mx-auto">
      <div class="mb-12 max-w-2xl">
        <h1 class="font-display text-vinco-cream mb-4">
          <MultilineText text={t.home.categories_title} />
        </h1>
        <p class="text-vinco-cream/70 leading-relaxed">{t.work.categories_intro}</p>
      </div>

      <CategoryNav categories={categories} locale={locale} />

      <div>
        {
          categories.map((cat) => (
            <CategorySection
              slug={cat.slug}
              label={cat.label[locale]}
              items={getCategoryItems(cat.slug)}
              locale={locale}
            />
          ))
        }
      </div>
    </div>
  </section>
</Base>

<script>
  function scrollToHash() {
    const hash = window.location.hash.slice(1);
    if (!hash) return;

    const target = document.getElementById(hash);
    if (!target) return;

    requestAnimationFrame(() => {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  scrollToHash();
  window.addEventListener('hashchange', scrollToHash);
</script>
